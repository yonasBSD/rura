"                               ┌ Keys ───────────────────────────────┐                              "
"                               │enter     - Execute full command     │                              "
"                               │alt+\     - Execute until cursor     │                              "
"                               │alt+|     - Execute before cursor    │                              "
"                               │alt+i     - Reset input              │                              "
"                               │                                     │                              "
"                               │shift+tab - Go to previous subcommand│                              "
"                               │tab       - Go to next subcommand    │                              "
"                               │                                     │                              "
"                               │ctrl+p    - History previous item    │                              "
"                               │ctrl+n    - History next item        │                              "
"                               │                                     │                              "
"                               │up        - Scroll up                │                              "
"                               │down      - Scroll down              │                              "
"                               │pageup    - Scroll page up           │                              "
"                               │pagedown  - Scroll page down         │                              "
"                               │                                     │                              "
"                               │alt+right - Scroll right             │                              "
"                               │alt+left  - Scroll left              │                              "
"                               │                                     │                              "
"                               │alt+w     - Wrap output lines        │                              "
